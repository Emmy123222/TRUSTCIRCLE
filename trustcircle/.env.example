# ─── Wallet Gate ──────────────────────────────────────────────────
# Set to "true" to require wallet connection before entering the app
VITE_REQUIRE_WALLET=false

# ─── Contract Addresses ───────────────────────────────────────────
# Sepolia Testnet (Zama fhEVM)
VITE_TRUST_SCORE_CONTRACT=your_trust_score_contract_address
VITE_ENCRYPTED_POSTS_CONTRACT=your_encrypted_posts_contract_address
VITE_ENCRYPTED_DM_CONTRACT=your_encrypted_dm_contract_address
VITE_AGENT_REGISTRY_CONTRACT=your_agent_registry_contract_address

# Filecoin Calibration Testnet
VITE_FILECOIN_REGISTRY_CONTRACT=your_filecoin_registry_contract_address

# Flow Testnet
VITE_FLOW_SOCIAL_CONTRACT=your_flow_social_contract_address
VITE_FLOW_CONTRACT_ADDRESS=your_flow_contract_address

# ─── Network ──────────────────────────────────────────────────────
VITE_DEFAULT_CHAIN_ID=11155111

# ─── RPC Endpoints ────────────────────────────────────────────────
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
VITE_FLOW_RPC_URL=https://rest-testnet.onflow.org

# ─── Storacha (Web3.Storage) Configuration ───────────────────────
VITE_STORACHA_SPACE_DID=your_storacha_space_did

# ─── AI Agent ─────────────────────────────────────────────────────
VITE_AGENT_URL=https://trustcircle.onrender.com